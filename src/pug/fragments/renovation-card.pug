mixin renovation-card(policy, risk, dateContrat, dateMaturity, price, stateHeader)
    .renovation-card
        .renovation-card__policy= policy
        .renovation-card__risk= risk
        .renovation-card__date-contrat= dateContrat
        .renovation-card__date-maturity= dateMaturity
        .renovation-card__price= price
        .renovation-card__state= stateHeader
            block
mixin state-policy(icon, text)
    .state-policy
        span.state-policy__icon.icon(class=icon)
        span.state-policy__text= text